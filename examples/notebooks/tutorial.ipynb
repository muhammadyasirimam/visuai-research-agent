 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🔬 VisuAI Research Agent Tutorial\n",
    "\n",
    "**Author:** Muhammad Yasir Imam\n",
    "\n",
    "This notebook demonstrates how to use VisuAI for research data visualization."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "from visuai import ResearchAgent\n",
    "\n",
    "# Create sample data\n",
    "data = pd.DataFrame({\n",
    "    'feature_1': np.random.randn(200),\n",
    "    'feature_2': np.random.randn(200),\n",
    "    'feature_3': np.random.randn(200),\n",
    "    'category': np.random.choice(['A', 'B', 'C'], 200)\n",
    "})\n",
    "\n",
    "data.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Initialize agent\n",
    "agent = ResearchAgent(domain="machine_learning")\n",
    "agent.load_data(data)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run analysis\n",
    "result = agent.run(\n",
    "    query="Show me feature distributions, correlations, and category breakdowns",\n",
    "    export_formats=["html", "png"],\n",
    "    xai_enabled=True\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Display results\n",
    "result.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Chat with your data\n",
    "agent.chat("What is the correlation between feature_1 and feature_2?")"
   ]
  }
 ],
